{
  "name": "lunara-frontend",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "node node_modules/vite/bin/vite.js",
    "build": "node node_modules/typescript/bin/tsc -p tsconfig.app.json && node node_modules/vite/bin/vite.js build",
    "lint": "node node_modules/eslint/bin/eslint.js .",
    "lint:fix": "node node_modules/eslint/bin/eslint.js . --fix",
    "format": "npx prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "npx prettier --check \"src/**/*.{ts,tsx,css}\"",
    "preview": "node node_modules/vite/bin/vite.js preview",
    "test": "node node_modules/jest/bin/jest.js",
    "test:watch": "node node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node node_modules/jest/bin/jest.js --coverage",
    "test:log": "node node_modules/jest/bin/jest.js --ci --runInBand --json --outputFile=jest-results.json --verbose",
    "type-check": "node node_modules/typescript/bin/tsc --noEmit",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^6.5.1",
    "@fortawesome/free-brands-svg-icons": "^6.5.1",
    "@fortawesome/free-solid-svg-icons": "^6.5.1",
    "@fortawesome/react-fontawesome": "^0.2.0",
    "@hookform/resolvers": "^5.1.1",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@types/dompurify": "^3.0.5",
    "@types/react-big-calendar": "^1.16.1",
    "axios": "^1.9.0",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "quill": "2.0.2",
    "react": "^18.2.0",
    "react-big-calendar": "^1.18.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.60.0",
    "react-icons": "^5.5.0",
    "react-quill-new": "3.7.0",
    "react-router-dom": "^6.22.1",
    "react-toastify": "^11.0.5",
    "socket.io-client": "^4.7.2",
    "three": "^0.183.2",
    "zod": "^3.25.75"
  },
  "overrides": {
    "quill": "$quill"
  },
  "devDependencies": {
    "@mswjs/interceptors": "^0.13.6",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.17.46",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.17",
    "cross-fetch": "^4.1.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lines-and-columns": "^2.0.4",
    "msw": "^1.3.5",
    "postcss": "^8.4.35",
    "postcss-import": "^16.1.0",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.3.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vite": "^6.4.1"
  }
}
